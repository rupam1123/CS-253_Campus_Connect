{
 "version": 2,
 "installCommand": "npm install --prefix backend && npm install --prefix campus-connect-frontend",
 "buildCommand": "npm run build --prefix campus-connect-frontend",
 "outputDirectory": "campus-connect-frontend/dist",
 "routes": [
  {
   "src": "^/api/(.*)$",
   "dest": "/api/[[...route]].js"
  },
  {
   "handle": "filesystem"
  },
  {
   "src": "/(.*)",
   "dest": "/index.html"
  }
 ]
}
